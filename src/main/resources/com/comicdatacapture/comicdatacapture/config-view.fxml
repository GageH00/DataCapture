<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.comicdatacapture.comicdatacapture.controller.cameraConfigController"
            prefWidth="1200" prefHeight="860">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <top>
        <VBox spacing="12" BorderPane.alignment="CENTER_LEFT">
            <Label text="Configuration"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Set up camera devices, output location, and define the data fields captured each session."
                   style="-fx-font-size: 13px; -fx-text-fill: #616161;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="cameraAStatusLabel" text="Camera A: —"
                       style="-fx-border-color: #bdbdbd; -fx-border-radius: 20;
                              -fx-background-radius: 20; -fx-padding: 4 10 4 10;"/>
                <Label fx:id="cameraBStatusLabel" text="Camera B: —"
                       style="-fx-border-color: #bdbdbd; -fx-border-radius: 20;
                              -fx-background-radius: 20; -fx-padding: 4 10 4 10;"/>
                <Label fx:id="outputFolderStatusLabel" text="Output Folder: Not Set"
                       style="-fx-border-color: #bdbdbd; -fx-border-radius: 20;
                              -fx-background-radius: 20; -fx-padding: 4 10 4 10;"/>
            </HBox>

            <!-- Profile management -->
            <HBox spacing="16" alignment="CENTER_LEFT"
                  style="-fx-border-color: #e0e0e0; -fx-border-radius: 6;
                         -fx-background-color: white; -fx-background-radius: 6;">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <VBox spacing="4" prefWidth="220">
                    <Label text="Profile Name" style="-fx-font-size: 11px; -fx-text-fill: #616161;"/>
                    <TextField fx:id="profileNameField" promptText="e.g. Comic Intake"/>
                </VBox>
                <VBox spacing="4" prefWidth="240">
                    <Label text="Load Saved Profile" style="-fx-font-size: 11px; -fx-text-fill: #616161;"/>
                    <ComboBox fx:id="savedProfilesComboBox"
                              promptText="— select a profile —" maxWidth="Infinity"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="4">
                    <Label text=" " style="-fx-font-size: 11px;"/>
                    <HBox spacing="8">
                        <Button text="Load"         onAction="#onLoadProfile"   prefWidth="80"/>
                        <Button text="Save Profile"  onAction="#onSaveProfile"
                                prefWidth="110" style="-fx-font-weight: bold;"/>
                        <Button text="Delete"        onAction="#onDeleteProfile"
                                prefWidth="80" style="-fx-text-fill: #c62828;"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <VBox.margin><Insets top="16"/></VBox.margin>

            <!-- LEFT: Camera setup -->
            <VBox spacing="16" prefWidth="560"
                  style="-fx-border-color: #e0e0e0; -fx-border-radius: 6;
                         -fx-background-color: white; -fx-background-radius: 6;">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label text="Camera Setup" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <VBox spacing="6">
                    <Label text="Camera A Device"/>
                    <ComboBox fx:id="cameraAComboBox" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Camera B Device"/>
                    <ComboBox fx:id="cameraBComboBox" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Resolution"/>
                    <ComboBox fx:id="resolutionComboBox" maxWidth="Infinity"/>
                </VBox>

                <!--
                  Preview thumbnails — fitWidth/fitHeight set to the thumbnail
                  dimensions directly.  preserveRatio=true scales the live frame
                  to fit within 240×160 without ever exceeding it.
                  No binding, no maxWidth tricks needed.
                -->
                <HBox spacing="12">
                    <StackPane style="-fx-border-color: #9e9e9e; -fx-background-color: #f5f5f5;
                                      -fx-border-radius: 4;">
                        <ImageView fx:id="cameraAImageView"
                                   fitWidth="240" fitHeight="160"
                                   preserveRatio="true"
                                   StackPane.alignment="CENTER"/>
                        <Label fx:id="cameraAOverlayLabel" text="Camera A Preview"
                               style="-fx-text-fill: #9e9e9e;"/>
                    </StackPane>
                    <StackPane style="-fx-border-color: #9e9e9e; -fx-background-color: #f5f5f5;
                                      -fx-border-radius: 4;">
                        <ImageView fx:id="cameraBImageView"
                                   fitWidth="240" fitHeight="160"
                                   preserveRatio="true"
                                   StackPane.alignment="CENTER"/>
                        <Label fx:id="cameraBOverlayLabel" text="Camera B Preview"
                               style="-fx-text-fill: #9e9e9e;"/>
                    </StackPane>
                </HBox>

                <HBox spacing="10">
                    <Button text="▶ Start Preview" onAction="#onStartPreview" prefWidth="140"/>
                    <Button text="■ Stop Preview"  onAction="#onStopPreview"  prefWidth="140"/>
                </HBox>
                <Separator/>
                <Label text="Output Folder" style="-fx-font-weight: bold;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="outputFolderField"
                               promptText="/path/to/output" HBox.hgrow="ALWAYS"/>
                    <Button text="Browse…" onAction="#onBrowseOutputFolder" prefWidth="90"/>
                </HBox>
            </VBox>

            <!-- RIGHT: Field builder -->
            <VBox spacing="14" HBox.hgrow="ALWAYS"
                  style="-fx-border-color: #e0e0e0; -fx-border-radius: 6;
                         -fx-background-color: white; -fx-background-radius: 6;">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label text="Custom Capture Fields"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label text="Define the data fields operators fill in for each item captured during a session."
                       style="-fx-font-size: 12px; -fx-text-fill: #757575;"/>
                <VBox spacing="8"
                      style="-fx-border-color: #e8e8e8; -fx-border-radius: 4;
                             -fx-background-color: #fafafa; -fx-background-radius: 4;">
                    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Field Label"/>
                            <TextField fx:id="newFieldLabelInput" promptText="e.g. Issue Number"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Type"/>
                            <ComboBox fx:id="newFieldTypeComboBox" prefWidth="120"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="4">
                        <Label text="Dropdown Options (comma-separated)"
                               style="-fx-font-size: 11px; -fx-text-fill: #616161;"/>
                        <TextField fx:id="newFieldDropdownOptionsInput"
                                   promptText="e.g. Fine, Good, Fair, Poor"/>
                    </VBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <CheckBox fx:id="newFieldRequiredCheckBox" text="Required field"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="+ Add Field" onAction="#onAddField"
                                style="-fx-font-weight: bold;" prefWidth="110"/>
                    </HBox>
                </VBox>
                <Label text="Defined Fields"
                       style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent;">
                    <VBox fx:id="fieldListContainer" spacing="6"/>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="20"/></padding>
            <Button text="Cancel" onAction="#onCancel" prefWidth="120"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Save Configuration" onAction="#onSaveConfiguration"
                    style="-fx-font-weight: bold;" prefWidth="180"/>
        </HBox>
    </bottom>
</BorderPane>
