<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.comicdatacapture.comicdatacapture.controller.mainViewController"
            prefWidth="1200" prefHeight="800">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <top>
        <VBox spacing="8" BorderPane.alignment="CENTER_LEFT">
            <padding><Insets bottom="12"/></padding>
            <Label text="Comic Intake Design"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Initial load state: verify cameras, confirm configuration, and start a session."
                   style="-fx-font-size: 13px;"/>
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label fx:id="cameraAStatusLabel" text="Camera A: Not Assigned"
                       style="-fx-border-color: #bdbdbd; -fx-border-radius: 20;
                              -fx-background-radius: 20; -fx-padding: 4 12 4 12;"/>
                <Label fx:id="cameraBStatusLabel" text="Camera B: Not Assigned"
                       style="-fx-border-color: #bdbdbd; -fx-border-radius: 20;
                              -fx-background-radius: 20; -fx-padding: 4 12 4 12;"/>
                <Label fx:id="outputFolderStatusLabel" text="Output Folder: Not Set"
                       style="-fx-border-color: #bdbdbd; -fx-border-radius: 20;
                              -fx-background-radius: 20; -fx-padding: 4 12 4 12;"/>
                <Label fx:id="profileStatusLabel" text="Profile: Default"
                       style="-fx-border-color: #bdbdbd; -fx-border-radius: 20;
                              -fx-background-radius: 20; -fx-padding: 4 12 4 12;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="16" alignment="TOP_CENTER">
            <VBox.margin><Insets top="8"/></VBox.margin>

            <!-- Camera A card -->
            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-border-color: #bdbdbd; -fx-border-radius: 6;
                         -fx-background-color: white; -fx-background-radius: 6;">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label text="Camera A Preview"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <!--
                  fitWidth / fitHeight set to the MAXIMUM pixels we ever want to
                  display.  preserveRatio=true means JavaFX scales the image to fit
                  within this box — it never exceeds these dimensions.
                  The StackPane's preferred size is driven by these values, so it
                  stays fixed regardless of what the image resolution is.
                -->
                <StackPane fx:id="cameraAPreview"
                           style="-fx-border-color: #9e9e9e; -fx-background-color: #f0f0f0;
                                  -fx-border-radius: 4; -fx-background-radius: 4;">
                    <ImageView fx:id="cameraAImageView"
                               fitWidth="520" fitHeight="280"
                               preserveRatio="true"
                               StackPane.alignment="CENTER"/>
                    <Label fx:id="cameraAOverlayLabel"
                           text="No preview — assign a camera in Configuration"
                           style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"
                           wrapText="true" maxWidth="300"
                           StackPane.alignment="CENTER"/>
                </StackPane>
                <Label fx:id="cameraADeviceLabel" text="Device: —"
                       style="-fx-font-size: 12px; -fx-text-fill: #616161;"/>
            </VBox>

            <!-- Camera B card -->
            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-border-color: #bdbdbd; -fx-border-radius: 6;
                         -fx-background-color: white; -fx-background-radius: 6;">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                <Label text="Camera B Preview"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <StackPane fx:id="cameraBPreview"
                           style="-fx-border-color: #9e9e9e; -fx-background-color: #f0f0f0;
                                  -fx-border-radius: 4; -fx-background-radius: 4;">
                    <ImageView fx:id="cameraBImageView"
                               fitWidth="520" fitHeight="280"
                               preserveRatio="true"
                               StackPane.alignment="CENTER"/>
                    <Label fx:id="cameraBOverlayLabel"
                           text="No preview — assign a camera in Configuration"
                           style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"
                           wrapText="true" maxWidth="300"
                           StackPane.alignment="CENTER"/>
                </StackPane>
                <Label fx:id="cameraBDeviceLabel" text="Device: —"
                       style="-fx-font-size: 12px; -fx-text-fill: #616161;"/>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="20"/></padding>
            <Button fx:id="configButton" text="Configuration"
                    prefWidth="160" onAction="#handleConfig"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="startButton" text="Start Session"
                    prefWidth="180" onAction="#handleStartSession"
                    style="-fx-font-weight: bold;"/>
        </HBox>
    </bottom>
</BorderPane>
